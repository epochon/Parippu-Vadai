<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
  <link rel="stylesheet" href="/styles.css">

  


<style>
nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 40px; /* bigger padding */
  background-color: #ffffff; /* green background, you can change it */
  color: white;
  box-shadow: 0 4px 8px rgba(0,0,0,0.2);
  border-radius: 80px; 
  
}

nav h1.farm {
  font-size: 48px;  /* increased size */
  margin: 0;
  font-weight: bold;
}

nav h1.farm a {
  text-decoration: none;
  color: rgb(26, 197, 0); /* keep contrast */
}

nav ul {
  list-style: none;
  display: flex;
  gap: 20px;
  margin: 0;
  padding: 0;
}

nav ul li {
  font-size: 20px; /* bigger text */
}

nav ul li a {
  text-decoration: none;
  color: rgb(0, 0, 0);
  font-weight: 500;
}

nav ul li a.btn {
  background: #ff9800; /* orange button */
  padding: 8px 14px;
  border-radius: 6px;
  transition: 0.3s;
}

nav ul li a.btn:hover {
  background: #e68900;
}

</style>
</head>
<body>
  <nav>
    <h1 class="farm"><a href="/">FARMLINK</a></h1>
    <ul>
      <% if (user) { %>
      <li>Welcome, <%= user.email %></li>
      <li><a href="/logout">Log out</a></li>
      <% } else{%>
      <li><a href="/login">Log in</a></li>
      <li><a href="/signup" class="btn">Sign up</a></li>
      <% } %>
    </ul>
  </nav>



